{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "kos Process Eval Contract",
  "type": "object",
  "properties": {
    "version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "prompt_file": { "type": "string", "pattern": "^[^/]+\\.prompts\\.csv$" },
    "prompt_case_id": { "type": "string", "minLength": 1 },
    "backend": { "const": "pi" },
    "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 600 },
    "thinking_level": {
      "enum": ["off", "minimal", "low", "medium", "high", "xhigh", "max"]
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "protocol": {
      "type": "object",
      "properties": {
        "required_skill_reads": { "$ref": "#/$defs/stringList" },
        "required_reads": { "$ref": "#/$defs/stringList" },
        "required_tools": { "$ref": "#/$defs/stringList" },
        "required_commands": { "$ref": "#/$defs/stringList" },
        "forbidden_tools": { "$ref": "#/$defs/stringList" },
        "forbidden_commands": { "$ref": "#/$defs/stringList" },
        "forbidden_path_fragments": { "$ref": "#/$defs/stringList" },
        "forbid_vault_changes": { "type": "boolean" }
      },
      "required": [
        "required_skill_reads",
        "required_reads",
        "required_tools",
        "required_commands",
        "forbidden_tools",
        "forbidden_commands",
        "forbidden_path_fragments",
        "forbid_vault_changes"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "id",
    "prompt_file",
    "prompt_case_id",
    "backend",
    "timeout_seconds",
    "thinking_level",
    "tools",
    "protocol"
  ],
  "additionalProperties": false,
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
