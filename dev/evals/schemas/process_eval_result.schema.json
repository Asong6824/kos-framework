{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "kos Process Eval Result",
  "type": "object",
  "properties": {
    "kind": { "const": "kos_process_eval" },
    "version": { "const": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "framework_version": { "type": "string" },
    "backend": { "type": "string" },
    "backend_version": { "type": "string" },
    "status": { "enum": ["pass", "fail"] },
    "metrics": {
      "type": "object",
      "properties": {
        "case_count": { "type": "integer", "minimum": 0 },
        "passed_cases": { "type": "integer", "minimum": 0 },
        "route": { "type": "object" },
        "required_step_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "forbidden_violation_count": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "case_count",
        "passed_cases",
        "route",
        "required_step_coverage",
        "forbidden_violation_count"
      ],
      "additionalProperties": false
    },
    "results": { "type": "array", "items": { "type": "object" } }
  },
  "required": [
    "kind",
    "version",
    "created_at",
    "framework_version",
    "backend",
    "backend_version",
    "status",
    "metrics",
    "results"
  ],
  "additionalProperties": false
}
